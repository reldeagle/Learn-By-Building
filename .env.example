# Pooled Neon connection string for application runtime in Preview and Production.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/database?sslmode=require"
# Direct Neon connection string for Prisma migrations. Do not use it for Vercel runtime traffic.
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-example.region.aws.neon.tech/database?sslmode=require"
# Use google-ai-studio in local, Preview, and Production environments.
LLM_PROVIDER="google-ai-studio"
# Required when LLM_PROVIDER is google-ai-studio.
GOOGLE_AI_STUDIO_API_KEY=""
# Local URL. In Vercel, set the HTTPS URL for the matching Preview or Production deployment.
NEXTAUTH_URL="http://localhost:3001"
# Generate a distinct random value for each deployed environment; never commit it.
NEXTAUTH_SECRET=""
# Google OAuth web client credentials. Required for Preview and Production sign-in.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Local development only. This provider is disabled in production.
AUTH_DEMO_PASSWORD=""
